namespace IconMaster
{
    // A drawing surface: the logical pixel grid plus the currently selected colour.
    runtimeclass DrawingContext
    {
        DrawingContext(Int32 width, Int32 height);

        Int32 PixelWidth{ get; };
        Int32 PixelHeight{ get; };

        Windows.UI.Color Color;

        Windows.UI.Color GetPixel(Int32 x, Int32 y);
        void SetPixel(Int32 x, Int32 y, Windows.UI.Color color);
        void Clear(Windows.UI.Color color);
    }

    // A drawing tool. Given a context and a pixel coordinate, it mutates the grid
    // (or, for the eyedropper, the context's current colour).
    interface ITool
    {
        void Draw(DrawingContext context, Int32 x, Int32 y);
    }

    // Paints the context's current colour at the pixel.
    [default_interface]
    runtimeclass Pen : ITool
    {
        Pen();
    }

    // Clears the pixel to transparent.
    [default_interface]
    runtimeclass Eraser : ITool
    {
        Eraser();
    }

    // Flood-fills the contiguous region of same-coloured pixels with the current colour.
    [default_interface]
    runtimeclass Fill : ITool
    {
        Fill();
    }

    // Picks the colour under the pixel into the context's current colour.
    [default_interface]
    runtimeclass Eyedropper : ITool
    {
        Eyedropper();
    }
}
