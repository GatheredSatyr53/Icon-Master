<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IconMaster.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IconMaster"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Icon Master">

    <Grid Padding="12" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Toolbox -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="6" Width="104">
            <StackPanel.Resources>
                <!-- Compact, icon-only toolbar buttons. Labels live in tooltips. -->
                <Style TargetType="Button">
                    <Setter Property="Width" Value="48" />
                    <Setter Property="Height" Value="38" />
                    <Setter Property="Padding" Value="0" />
                </Style>
                <Style TargetType="RadioButton">
                    <Setter Property="Width" Value="48" />
                    <Setter Property="Height" Value="38" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
            </StackPanel.Resources>

            <TextBlock Text="File" Style="{StaticResource CaptionTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnNew" ToolTipService.ToolTip="New  (Ctrl+N)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="N" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnOpen" ToolTipService.ToolTip="Open&#x2026;  (Ctrl+O)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8E5;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnSave" ToolTipService.ToolTip="Save as PNG&#x2026;  (Ctrl+S)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnExportIco" ToolTipService.ToolTip="Export ICO&#x2026;  (Ctrl+E)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE896;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="E" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>

            <TextBlock Text="Canvas" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <ComboBox x:Name="SizeCombo" Width="48"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Canvas size for New / Resize">
                    <ComboBoxItem Content="16" />
                    <ComboBoxItem Content="32" IsSelected="True" />
                    <ComboBoxItem Content="48" />
                    <ComboBoxItem Content="64" />
                    <ComboBoxItem Content="128" />
                    <ComboBoxItem Content="256" />
                </ComboBox>
                <Button Click="OnResizeCanvas" ToolTipService.ToolTip="Resize canvas to the chosen size (top-left anchored)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE740;" FontSize="16" />
                </Button>
            </StackPanel>

            <TextBlock Text="Edit" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnUndo" ToolTipService.ToolTip="Undo  (Ctrl+Z)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A7;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Z" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnRedo" ToolTipService.ToolTip="Redo  (Ctrl+Y)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A6;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Y" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>

            <TextBlock Text="Tools" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton Tag="pen" GroupName="tools" IsChecked="True"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Pen">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="16" />
                </RadioButton>
                <RadioButton Tag="eraser" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Eraser">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE75C;" FontSize="16" />
                </RadioButton>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton Tag="fill" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Fill">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE790;" FontSize="16" />
                </RadioButton>
                <RadioButton Tag="eyedropper" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Eyedropper">
                    <PathIcon Width="16" Height="16"
                              Data="M10.5,2 H14 V5.5 H10.5 Z M11,4.5 L12.5,6 L6,12.5 L4.5,11 Z M4.5,11 L6,12.5 L3,14 Z" />
                </RadioButton>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton Tag="line" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Line">
                    <PathIcon Width="16" Height="16"
                              Data="M2.2,12.2 L3.8,13.8 L13.8,3.8 L12.2,2.2 Z" />
                </RadioButton>
                <RadioButton Tag="rectangle" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Rectangle">
                    <PathIcon Width="16" Height="16"
                              Data="F0 M2,4 H14 V12 H2 Z M4,6 H12 V10 H4 Z" />
                </RadioButton>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton Tag="ellipse" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Ellipse">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEA3A;" FontSize="16" />
                </RadioButton>
                <RadioButton Tag="select" GroupName="tools"
                             Checked="OnToolSelected" ToolTipService.ToolTip="Select">
                    <PathIcon Width="16" Height="16"
                              Data="M2,3 H6 V4 H3 V7 H2 Z M14,3 H10 V4 H13 V7 H14 Z M2,13 H6 V12 H3 V9 H2 Z M14,13 H10 V12 H13 V9 H14 Z" />
                </RadioButton>
            </StackPanel>

            <TextBlock Text="Selection" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnSelectAll" ToolTipService.ToolTip="Select all  (Ctrl+A)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B3;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="A" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnDeselect" ToolTipService.ToolTip="Deselect  (Esc)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnCopy" ToolTipService.ToolTip="Copy  (Ctrl+C)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C8;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="C" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnCut" ToolTipService.ToolTip="Cut  (Ctrl+X)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C6;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="X" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Click="OnPaste" ToolTipService.ToolTip="Paste  (Ctrl+V)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77F;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="V" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnDelete" ToolTipService.ToolTip="Delete  (Del)">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="16" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Delete" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Canvas area -->
        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabView x:Name="Tabs" Grid.Row="0"
                     IsAddTabButtonVisible="True"
                     SelectionChanged="OnTabSelectionChanged"
                     AddTabButtonClick="OnAddTab"
                     TabCloseRequested="OnTabCloseRequested" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="&#x2212;" Click="OnZoomOut" ToolTipService.ToolTip="Zoom out" />
                <TextBlock x:Name="ZoomText" VerticalAlignment="Center" MinWidth="52" TextAlignment="Center" Text="1600%" />
                <Button Content="&#x2b;" Click="OnZoomIn" ToolTipService.ToolTip="Zoom in" />
            </StackPanel>

            <ScrollViewer Grid.Row="2"
                          ZoomMode="Disabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto"
                          VerticalScrollMode="Auto"
                          Background="#FF808080">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"
                        BorderBrush="#FF404040" BorderThickness="1">
                    <Image x:Name="CanvasImage"
                           Stretch="None"
                           PointerPressed="OnCanvasPointerPressed"
                           PointerMoved="OnCanvasPointerMoved"
                           PointerReleased="OnCanvasPointerReleased" />
                </Border>
            </ScrollViewer>

            <TextBlock x:Name="StatusText" Grid.Row="3" Text="Left button draws, right button erases." />
        </Grid>

        <!-- Palette -->
        <StackPanel Grid.Column="2" Spacing="8">
            <TextBlock Text="Colour" Style="{StaticResource CaptionTextBlockStyle}" />

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Click="OnSwatchClick" Tag="#FF000000" Padding="0" ToolTipService.ToolTip="Black">
                    <Border Width="22" Height="22" Background="#FF000000" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FF808080" Padding="0" ToolTipService.ToolTip="Gray">
                    <Border Width="22" Height="22" Background="#FF808080" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FFFFFFFF" Padding="0" ToolTipService.ToolTip="White">
                    <Border Width="22" Height="22" Background="#FFFFFFFF" BorderBrush="Gray" BorderThickness="1" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FFE81123" Padding="0" ToolTipService.ToolTip="Red">
                    <Border Width="22" Height="22" Background="#FFE81123" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FFFF8C00" Padding="0" ToolTipService.ToolTip="Orange">
                    <Border Width="22" Height="22" Background="#FFFF8C00" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FFFFF100" Padding="0" ToolTipService.ToolTip="Yellow">
                    <Border Width="22" Height="22" Background="#FFFFF100" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Click="OnSwatchClick" Tag="#FF107C10" Padding="0" ToolTipService.ToolTip="Green">
                    <Border Width="22" Height="22" Background="#FF107C10" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FF0078D7" Padding="0" ToolTipService.ToolTip="Blue">
                    <Border Width="22" Height="22" Background="#FF0078D7" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FF00B7C3" Padding="0" ToolTipService.ToolTip="Cyan">
                    <Border Width="22" Height="22" Background="#FF00B7C3" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FF881798" Padding="0" ToolTipService.ToolTip="Purple">
                    <Border Width="22" Height="22" Background="#FF881798" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#FF8E562E" Padding="0" ToolTipService.ToolTip="Brown">
                    <Border Width="22" Height="22" Background="#FF8E562E" />
                </Button>
                <Button Click="OnSwatchClick" Tag="#00000000" Padding="0" ToolTipService.ToolTip="Transparent">
                    <Border Width="22" Height="22" BorderBrush="Gray" BorderThickness="1">
                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Button>
            </StackPanel>

            <ColorPicker x:Name="ColorPickerControl"
                         IsAlphaEnabled="True"
                         IsMoreButtonVisible="True"
                         ColorSpectrumShape="Box"
                         ColorChanged="OnColorChanged"
                         />
        </StackPanel>
    </Grid>
</Window>
