<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IconMaster.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IconMaster"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Icon Master">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="Icon Master" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
        <TextBlock Text="Pixel icon editor — WinUI 3 / C++/WinRT scaffold" HorizontalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" />
        <Button x:Name="myButton" Click="myButton_Click" HorizontalAlignment="Center">Click Me</Button>
    </StackPanel>
</Window>
