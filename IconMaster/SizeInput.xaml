<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="IconMaster.SizeInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <CheckBox x:Name="SquareBox" Content="Square" Checked="OnSquareChanged" />
        <NumberBox x:Name="WidthBox" Header="Width" Minimum="1" Maximum="1024"
                   SpinButtonPlacementMode="Inline" ValueChanged="OnWidthChanged" />
        <NumberBox x:Name="HeightBox" Header="Height" Minimum="1" Maximum="1024"
                   SpinButtonPlacementMode="Inline" ValueChanged="OnHeightChanged" />
    </StackPanel>
</UserControl>
